# 猫笔刀文章 RAG Agent 配置

# 文章源目录（必填）
ARTICLE_SOURCE_DIR=

# 数据目录（默认 data）
DATA_DIR=data

# OpenAI-compatible API 配置（LLM 共用，Embedding 已单独配置火山方舟）
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
EMBEDDING_MODEL=
LLM_MODEL=

# --- Embedding 配置 ---
# 厂商选择：openai（默认）或 volcengine
EMBEDDING_PROVIDER=volcengine
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_API_KEY=
# EMBEDDING_MODEL 填写火山方舟的推理接入点 ID（ep-xxx）

# 检索参数
TOP_K=8
SIMILARITY_THRESHOLD=0.3
RAG_CONTEXT_TOKEN_BUDGET=6000
VECTOR_STORE=qdrant
KEYWORD_STORE=elasticsearch
RETRIEVAL_MODE=hybrid_rrf

# Qdrant（建议通过 k8s/orbstack + port-forward 访问）
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=mooomoocat_articles_v1

# Elasticsearch（建议通过 k8s/orbstack + port-forward 访问）
ELASTICSEARCH_URL=https://127.0.0.1:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_CA_CERT_PATH=
ELASTICSEARCH_INDEX=mooomoocat_article_chunks_v1
ELASTICSEARCH_ANALYZER=smartcn

# Hybrid retrieval
HYBRID_DENSE_TOP_K=24
HYBRID_KEYWORD_TOP_K=24
HYBRID_FINAL_TOP_K=8
HYBRID_RRF_K=60

# 日志级别
LOG_LEVEL=INFO

# --- 以下为可选覆盖项，仅当 Embedding/LLM 使用不同服务时配置 ---

# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=
# LLM_BASE_URL=
# LLM_API_KEY=
