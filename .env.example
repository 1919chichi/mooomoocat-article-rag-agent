# 猫笔刀文章 RAG Agent 配置

# 文章源目录（必填）
ARTICLE_SOURCE_DIR=

# 数据目录（默认 data）
DATA_DIR=data

# OpenAI-compatible API 配置（Embedding 和 LLM 共用）
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
EMBEDDING_MODEL=
LLM_MODEL=

# 检索参数
TOP_K=8
SIMILARITY_THRESHOLD=0.5
RAG_CONTEXT_TOKEN_BUDGET=6000

# 日志级别
LOG_LEVEL=INFO

# --- 以下为可选覆盖项，仅当 Embedding/LLM 使用不同服务时配置 ---

# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=
# LLM_BASE_URL=
# LLM_API_KEY=
